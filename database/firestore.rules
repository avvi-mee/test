rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================
    // Helper Functions
    // ========================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return getUserData().role;
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserRole() == 'superadmin';
    }

    function isAdmin() {
      return isAuthenticated() && (getUserRole() == 'admin' || isSuperAdmin());
    }

    function isTenantOwner(tenantId) {
      let tenantData = get(/databases/$(database)/documents/tenants/$(tenantId)).data;
      return isAuthenticated() &&
        (tenantData.ownerId == request.auth.uid
         || tenantData.ownerUid == request.auth.uid
         || tenantData.email == request.auth.token.email);
    }

    function isTenantEmployee(tenantId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/tenants/$(tenantId)/employees/$(request.auth.uid));
    }

    function isTenantMember(tenantId) {
      return isTenantOwner(tenantId) || isTenantEmployee(tenantId) || isSuperAdmin();
    }

    // Role helpers — supports both legacy `role: string` and current `roles: string[]`
    function getEmployeeRoles(tenantId) {
      let emp = get(/databases/$(database)/documents/tenants/$(tenantId)/employees/$(request.auth.uid)).data;
      return emp.roles != null ? emp.roles : [emp.role];
    }

    function hasRole(tenantId, role) {
      return isAuthenticated() && isTenantEmployee(tenantId) && getEmployeeRoles(tenantId).hasAny([role]);
    }

    function isTenantAdmin(tenantId) {
      return isAuthenticated() && (isTenantOwner(tenantId) || (isTenantEmployee(tenantId) && getEmployeeRoles(tenantId).hasAny(['owner', 'admin'])));
    }

    // ========================================
    // Users Collection
    // ========================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    // ========================================
    // Customers Collection
    // ========================================
    match /customers/{customerId} {
      allow read, write: if isOwner(customerId);
    }

    // ========================================
    // Tenants Collection
    // ========================================
    match /tenants/{tenantId} {
      // Public: only approved/active tenants (storefront needs slug resolution)
      // Full access: tenant members and superadmin
      allow read: if isTenantMember(tenantId)
                  || isSuperAdmin()
                  || resource.data.status == 'active'
                  || (isAuthenticated() && resource.data.email == request.auth.token.email)
                  || (isAuthenticated() && resource.data.ownerUid == request.auth.uid);
      allow update: if isTenantOwner(tenantId) || isSuperAdmin();
      allow create: if isAuthenticated();

      // ========================================
      // Tenant Subcollections
      // ========================================

      // Brand & Theme — public read (storefront), owner write
      match /brand/config {
        allow read: if true;
        allow write: if isTenantOwner(tenantId);
      }
      match /theme/config {
        allow read: if true;
        allow write: if isTenantOwner(tenantId);
      }

      // Website pages — public read (storefront), owner write
      match /pages/{pageId} {
        allow read: if true;
        allow write: if isTenantOwner(tenantId);

        match /projects/{projectId} {
          allow read: if true;
          allow write: if isTenantOwner(tenantId);
        }
        match /items/{itemId} {
          allow read: if true;
          allow write: if isTenantOwner(tenantId);
        }
      }

      // Custom pages — public read (storefront nav), owner write
      match /customPages/{pageId} {
        allow read: if true;
        allow write: if isTenantMember(tenantId);
      }

      match /websiteConfig/settings {
        allow read: if true;
        allow write: if isTenantOwner(tenantId);
      }

      // Portfolio — public read (storefront), tenant member write
      match /portfolio/{projectId} {
        allow read: if true;
        allow write: if isTenantMember(tenantId);
      }

      // Testimonials — public read (storefront), tenant member write
      match /testimonials/{testimonialId} {
        allow read: if true;
        allow write: if isTenantMember(tenantId);
      }

      // Team Members — public read (storefront about page), tenant member write
      match /teamMembers/{memberId} {
        allow read: if true;
        allow write: if isTenantMember(tenantId);
      }

      // Estimates — anonymous create (storefront), tenant members read/update
      match /estimates/{estimateId} {
        allow read: if isTenantMember(tenantId)
                    || (isAuthenticated() && resource.data.customerEmail == request.auth.token.email);
        allow create: if true;
        allow update: if isTenantMember(tenantId);
      }

      // Employees — tenant member read, owner create/delete, owner+self update
      match /employees/{employeeId} {
        allow read: if isTenantMember(tenantId);
        allow create, delete: if isTenantOwner(tenantId);
        allow update: if isTenantOwner(tenantId) || isOwner(employeeId);
      }

      // Leads — anonymous create (storefront), tenant members read/update/delete
      match /leads/{leadId} {
        allow read: if isTenantMember(tenantId);
        allow create: if true;
        allow update, delete: if isTenantMember(tenantId);

        // Activity log for leads
        match /activityLog/{logId} {
          allow read: if isTenantMember(tenantId);
          allow create: if isTenantMember(tenantId);
        }
      }

      // Consultations — anonymous create (storefront), tenant members read/update
      match /consultations/{consultationId} {
        allow read: if isTenantMember(tenantId);
        allow create: if true;
        allow update: if isTenantMember(tenantId);
      }

      // Activity logs (tenant-level) — tenant members only
      match /activityLogs/{logId} {
        allow read: if isTenantMember(tenantId);
        allow create: if isTenantMember(tenantId);
      }

      // Projects — tenant members + customer (own projects) + client portal
      match /projects/{projectId} {
        allow read: if isTenantMember(tenantId)
                    || (isAuthenticated() && resource.data.customerId == request.auth.uid)
                    || (isAuthenticated() && resource.data.clientAuthUid == request.auth.uid);
        allow create: if isTenantMember(tenantId);
        allow update: if isTenantMember(tenantId);

        match /activityLog/{logId} {
          allow read: if isTenantMember(tenantId);
          allow create: if isTenantMember(tenantId);
        }

        match /phases/{phaseId} {
          allow read: if isTenantMember(tenantId);
          allow write: if isTenantMember(tenantId);
        }

        match /tasks/{taskId} {
          allow read: if isTenantMember(tenantId);
          allow write: if isTenantMember(tenantId);
        }

        // Project files — tenant members + client (own project, visible files only)
        match /files/{fileId} {
          allow read: if isTenantMember(tenantId)
                      || (isAuthenticated()
                          && get(/databases/$(database)/documents/tenants/$(tenantId)/projects/$(projectId)).data.clientAuthUid == request.auth.uid
                          && resource.data.visibleToClient == true);
          allow write: if isTenantMember(tenantId);
        }

        // Client queries — tenant members read all; client can read/create for own project
        match /queries/{queryId} {
          allow read: if isTenantMember(tenantId)
                      || (isAuthenticated()
                          && get(/databases/$(database)/documents/tenants/$(tenantId)/projects/$(projectId)).data.clientAuthUid == request.auth.uid);
          allow create: if isAuthenticated()
                        && get(/databases/$(database)/documents/tenants/$(tenantId)/projects/$(projectId)).data.clientAuthUid == request.auth.uid
                        && request.resource.data.clientAuthUid == request.auth.uid;
          allow update: if isTenantMember(tenantId); // PM can respond
        }
      }

      // Invoices — tenant members + customer (own invoices)
      match /invoices/{invoiceId} {
        allow read: if isTenantMember(tenantId) || (isAuthenticated() && resource.data.clientId == request.auth.uid);
        allow create: if isTenantMember(tenantId);
        allow update: if isTenantMember(tenantId);

        match /payments/{paymentId} {
          allow read: if isTenantMember(tenantId);
          allow create: if isTenantMember(tenantId);
        }
      }

      // Vendor Bills — tenant members only
      match /vendorBills/{billId} {
        allow read, write: if isTenantMember(tenantId);

        match /payments/{paymentId} {
          allow read, write: if isTenantMember(tenantId);
        }
      }

      // Follow-ups — tenant members only
      match /followUps/{followUpId} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantMember(tenantId);
      }

      // Cities — public read (storefront city dropdown), owner write
      match /cities/{cityId} {
        allow read: if true;
        allow write: if isTenantOwner(tenantId);
      }

      // Pricing config — public read (storefront estimator), owner write
      match /pricing/config {
        allow read: if true;
        allow write: if isTenantOwner(tenantId);
      }

      // Counters — tenant members (for atomic invoice numbering)
      match /counters/{counterId} {
        allow read, write: if isTenantMember(tenantId);
      }

      // Vendors — tenant members only (owner/admin/accountant manage)
      match /vendors/{vendorId} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantOwner(tenantId);
      }

      // Client Accounts — tenant members can read, client can read their own, owner manages
      match /clientAccounts/{clientId} {
        allow read: if isTenantMember(tenantId) || request.auth.uid == clientId;
        allow write: if isTenantOwner(tenantId);
      }

      // Contract Templates — tenant members only
      match /contractTemplates/{templateId} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantMember(tenantId);
      }

      // Contracts — tenant members
      match /contracts/{contractId} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantMember(tenantId);

        match /activityLog/{logId} {
          allow read: if isTenantMember(tenantId);
          allow create: if isTenantMember(tenantId);
        }
      }
    }

    // ========================================
    // Activities Collection (super-admin audit)
    // ========================================
    match /activities/{activityId} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated();
    }

    // ========================================
    // Contract Token Index (public read for signing page)
    // ========================================
    match /contractTokenIndex/{token} {
      allow read: if true;   // Public: signing page reads by token
      allow write: if false; // Only backend (Admin SDK) can write
    }

    // ========================================
    // Catch-all rule
    // ========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
